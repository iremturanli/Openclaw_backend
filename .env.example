# Copy to `.env` and fill in. `.env` is gitignored.

# ── AI / voice ────────────────────────────────────────────────────────────
# OpenAI powers the live AI concierge (tool-calling agent). Without it the
# assistant falls back to the rule-based trip planner (demo mode).
STAYWALLET_OPENAI_API_KEY=your-openai-key-here
# ElevenLabs server-side TTS for the voice concierge (optional; device TTS
# fallback when unset).
STAYWALLET_ELEVENLABS_API_KEY=your-elevenlabs-key-here
# STAYWALLET_ELEVENLABS_VOICE_ID=

# ── Live search providers ─────────────────────────────────────────────────
# SerpApi key drives LIVE flights (Google Flights), hotels (Google Hotels)
# and restaurants (Google Local). Unset → sandbox/mock results.
STAYWALLET_SERPAPI_API_KEY=your-serpapi-key-here

# ── Cars (STAYWALLET_CAR_PROVIDER: mock | booking | sixt) ─────────────────
# "booking" uses the Booking.com Demand API v3.1 (POST /cars/search):
#   https://developers.booking.com/demand/docs/open-api/demand-api/cars
STAYWALLET_CAR_PROVIDER=mock
# STAYWALLET_BOOKING_DEMAND_TOKEN=
# STAYWALLET_BOOKING_AFFILIATE_ID=
# Sandbox host while testing:
# STAYWALLET_BOOKING_DEMAND_BASE_URL=https://demandapi-sandbox.booking.com/3.1
# Direct Sixt partner integration (reserved):
# STAYWALLET_SIXT_CLIENT_ID=
# STAYWALLET_SIXT_CLIENT_SECRET=

# ── Transfers (STAYWALLET_TRANSFER_PROVIDER: mock | uber) ─────────────────
# "uber" uses the Uber Guest Trips API:
#   estimates: POST /v1/guests/trips/estimates
#   booking:   POST /v1/guests/trips
# Docs:
#   https://developer.uber.com/docs/guest-rides/introduction
# Auth (first that is set wins): legacy server token → pasted access token →
# OAuth client_credentials (client id + secret, token minted automatically).
# New apps should use client id + secret with the `guests.trips` scope.
STAYWALLET_TRANSFER_PROVIDER=mock
# STAYWALLET_UBER_SERVER_TOKEN=
# STAYWALLET_UBER_ACCESS_TOKEN=
# STAYWALLET_UBER_CLIENT_ID=
# STAYWALLET_UBER_CLIENT_SECRET=
# STAYWALLET_UBER_OAUTH_SCOPES=guests.trips

# ── Payments ──────────────────────────────────────────────────────────────
# Demo wallet by default; set a Stripe key to enable the live (test) checkout.
# STAYWALLET_STRIPE_SECRET_KEY=sk_test_...
# STAYWALLET_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret (whsec_...) for POST /api/v1/payments/webhook. Get it when you
# register the endpoint in the Stripe dashboard (or `stripe listen`). Without it
# the webhook rejects all events, so server-side payment confirmation is off.
# STAYWALLET_STRIPE_WEBHOOK_SECRET=whsec_...

# ── Security ──────────────────────────────────────────────────────────────
# STAYWALLET_KEY_SIGNING_SECRET=change-me-in-prod
# STAYWALLET_AUTH_SECRET=change-me-in-prod

# ── Rate limiting (in-process; requests/minute per client IP) ─────────────
# STAYWALLET_RATE_LIMIT_ENABLED=true
# STAYWALLET_RATE_LIMIT_DEFAULT_PER_MINUTE=120
# STAYWALLET_RATE_LIMIT_AUTH_PER_MINUTE=10
# STAYWALLET_RATE_LIMIT_AI_PER_MINUTE=20
# Set true only behind a trusted proxy/load balancer that sets X-Forwarded-For.
# STAYWALLET_RATE_LIMIT_TRUST_FORWARDED=false

# ── PostgreSQL (see docker-compose.yml — `docker compose up -d db`) ───────
STAYWALLET_DATABASE_URL=postgresql+asyncpg://staywallet:staywallet@localhost:5544/staywallet
STAYWALLET_DATABASE_URL_SYNC=postgresql+psycopg2://staywallet:staywallet@localhost:5544/staywallet
